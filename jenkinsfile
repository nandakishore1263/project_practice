pipeline {
    agent any
    tools{
        maven 'Maven-3.9'
    }
    stages {
        stage('checkout'){
              steps{
                    checkout scm
                }
            }
        stage('compile'){
            steps{
                sh 'mvn compile'
            }
           }
        stage('test'){
            steps{
                sh 'mvn test'
            }
        }
        stage('package'){
           steps{
                sh 'mvn package -DskipTests'
           }
        }
        stage('target'){
            steps{
                archiveArtifacts artifacts: 'target/*.jar',
                                 fingerprint: true
            }
        }
stage('Login Feature Info') {
    steps {
        echo '========== LOGIN FEATURE =========='
        echo 'This build is for the Login feature!'
        echo "Branch  : ${GIT_BRANCH}"
        echo "Build # : ${BUILD_NUMBER}"
        echo "Commit  : ${GIT_COMMIT}"
    }
}
        }
    }

