pipeline {
    agent any
    tools{
        maven 'Maven-3.9'
    }
    stages {
        stage('checkout'){
              steps{
                    checkout scm
                }
            }
        stage('compile'){
            steps{
                sh 'mvn compile'
            }
           }
        stage('test'){
            steps{
                sh 'mvn test'
            }
        }
        stage('package'){
           steps{
                sh 'mvn package -DskipTests'
           }
        }
        stage('target'){
            steps{
                archiveArtifacts artifacts: 'target/*.jar',
                                 fingerprint: true
            }
        }
        }
    }

